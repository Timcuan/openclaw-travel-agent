# ─── App Settings ───────────────────────────────────────────────
APP_NAME=openclaw-travel-agent
APP_ENV=development
DEBUG=true

# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/travel_agent
DATABASE_SYNC_URL=postgresql://postgres:password@localhost:5432/travel_agent

# ─── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=600  # 10 minutes

# ─── Groq LLM (primary AI engine) ──────────────────────────────
# Get free key at https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ─── OpenAI (optional fallback intent parser) ───────────────────
OPENAI_API_KEY=sk-...

# ─── Telegram ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# ─── Midtrans Live Payment ──────────────────────────────────────
# Dapatkan Server Key di Dashboard Midtrans -> Settings -> Access Keys
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false

# ─── Train Providers ────────────────────────────────────────────
KAI_BASE_URL=https://booking.kai.id
TIKET_API_KEY=your_tiket_api_key
TIKET_BASE_URL=https://api.tiket.com
TRAVELOKA_API_KEY=your_traveloka_api_key

# ─── Flight Providers ───────────────────────────────────────────
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret
AMADEUS_BASE_URL=https://test.api.amadeus.com

KIWI_API_KEY=your_kiwi_api_key
KIWI_BASE_URL=https://api.tequila.kiwi.com

SKYSCANNER_API_KEY=your_skyscanner_api_key
SKYSCANNER_BASE_URL=https://partners.api.skyscanner.net

# ─── Hotel Providers ────────────────────────────────────────────
LITEAPI_KEY=your_liteapi_key
LITEAPI_BASE_URL=https://api.liteapi.travel/v3.0

BOOKING_CLIENT_ID=your_booking_client_id
BOOKING_CLIENT_SECRET=your_booking_client_secret

AGODA_API_KEY=your_agoda_api_key

# ─── Playwright ─────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
