[Unit]
Description=OpenClaw Travel Agent – Telegram Bot
Documentation=https://github.com/your-org/openclaw-travel-agent
After=network-online.target redis.service postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=openclaw
WorkingDirectory=/opt/openclaw-travel-agent
EnvironmentFile=/opt/openclaw-travel-agent/.env

# Start the bot
ExecStart=/opt/openclaw-travel-agent/venv/bin/python -m bot.telegram_bot

# Restart policy
Restart=always
RestartSec=5
StartLimitIntervalSec=300
StartLimitBurst=10

# Output logging
StandardOutput=append:/var/log/openclaw/telegram-bot.log
StandardError=append:/var/log/openclaw/telegram-bot.log

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/opt/openclaw-travel-agent /var/log/openclaw

[Install]
WantedBy=multi-user.target
